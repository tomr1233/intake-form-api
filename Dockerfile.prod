FROM alpine:3.21
RUN apk --no-cache add ca-certificates tzdata
RUN addgroup -S app && adduser -S app -G app
WORKDIR /app
COPY bin/server .
COPY migrations/ ./migrations/
COPY entrypoint.sh .
RUN chmod +x entrypoint.sh server
RUN chown -R app:app /app
USER app
EXPOSE 8080
ENTRYPOINT ["./entrypoint.sh"]
